# OpenAI API Key (Set to a real key to enable GPT-4o-mini, or leave as mock to run offline)
OPENAI_API_KEY=mock-key

# Google Gemini API Key (si se define, el orquestador usa Gemini en lugar de OpenAI)
GOOGLE_API_KEY=
GOOGLE_ORCHESTRATOR_MODEL=gemini-1.5-flash

# FiftyOne app server settings
FIFTYONE_PORT=5151
FIFTYONE_HOST=127.0.0.1

# SQLite database URL
DATABASE_URL=sqlite+aiosqlite:///:memory:
